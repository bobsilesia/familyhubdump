      "fields": {
        "state": {
          "name": "State",
          "description": "Target state (on/off)"
        }
      }
    },
    "reset_filter": {
      "name": "Reset water filter counter",
      "description": "Resets the filter life counter on the refrigerator"
    },
    "set_power_cool": {
      "name": "Set Power Cool",
      "description": "Turns Power Cool mode on/off",
      "fields": {
        "state": {
          "name": "State",
          "description": "Target state (on/off)"
        }
      }
    },
    "set_power_freeze": {
      "name": "Set Power Freeze",
      "description": "Turns Power Freeze mode on/off",
      "fields": {
        "state": {
          "name": "State",
          "description": "Target state (on/off)"
        }
      }
    }
  }
