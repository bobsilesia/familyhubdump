        "component": {
          "name": "Component",
          "description": "The component to target (e.g. main)"
        },
        "capability": {
          "name": "Capability",
          "description": "The capability to execute"
        },
        "command": {
          "name": "Command",
          "description": "The command to execute"
        },
        "arguments": {
          "name": "Arguments",
          "description": "List of arguments for the command"
        }
      }
    },
    "set_ice_maker": {
      "name": "Set ice maker state",
